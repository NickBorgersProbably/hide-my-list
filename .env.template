# Notion API credentials
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Signal
# E.164 phone number registered with signal-cli (required)
SIGNAL_ACCOUNT=
# Comma-separated E.164 numbers allowed to send messages (required; empty or unset refuses startup)
AUTHORIZED_PEERS=

# LLM proxy (primary LLM)
LLM_PROXY_BASE_URL=
LLM_PROXY_API_KEY=

# Timezone for reminder parsing and scheduled jobs (IANA identifier, e.g. America/Chicago)
USER_TZ=America/Chicago

# Ops alerts: separate Signal recipient for health-check failures
OPS_ALERT_SIGNAL_NUMBER=

# Optional integrations
OPENAI_API_KEY=

# LangSmith tracing (disabled by default; set both to enable)
# LANGSMITH_TRACING=true
# ALLOW_PRIVATE_TRACE_EXPORT=true
