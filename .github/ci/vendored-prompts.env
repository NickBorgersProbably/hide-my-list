# Vendored upstream prompts used by the v2 review pipeline.
#
# This file is the SHA pin for prompts we vendor from external
# open-source projects. The weekly update-ai-clis workflow checks
# upstream for newer SHAs against each repo+path pair and opens a
# refresh PR when one is detected. The refreshed prompt is regenerated
# by `.github/scripts/vendor-security-prompt.py`, which rewrites the
# fenced VENDORED PROMPT block inside the corresponding prompt file.

# Anthropic's open-source security audit prompt. Sourced from
# claudecode/prompts.py (function get_security_audit_prompt). The
# rendered body lands inside the BEGIN/END VENDORED PROMPT markers in
# .github/scripts/review/prompts/security-breadth.md.
#
# Bumping CCSR_PINNED_SHA without rerunning the vendor script will
# falsely advertise an unchanged prompt — only edit alongside a script
# run that regenerates security-breadth.md.
CCSR_REPO=anthropics/claude-code-security-review
CCSR_PROMPT_PATH=claudecode/prompts.py
CCSR_PINNED_SHA=
