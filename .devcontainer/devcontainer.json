{
  "name": "Hide My List (OpenClaw Agent)",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": "false"
    }
  },
  "onCreateCommand": "bash .devcontainer/setup-user.sh \"${localEnv:USER}\"",
  "initializeCommand": "bash .devcontainer/init-host-credentials.sh",
  "postCreateCommand": "bash .devcontainer/post-create.sh && bash .githooks/install-hooks.sh",
  "postStartCommand": "bash .devcontainer/fix-dns-order.sh && sudo chown -R \"$(id -u):$(id -g)\" /workspaces 2>/dev/null || true",
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/tmp/devcontainer-host/.claude,type=bind,readonly,consistency=cached",
    "source=${localEnv:HOME}/.gitconfig,target=/home/vscode/.gitconfig,type=bind,readonly,consistency=cached",
    "source=${localEnv:HOME}/.claude.json,target=/tmp/devcontainer-host/.claude.json,type=bind,readonly,consistency=cached",
    "source=${localEnv:HOME}/.bashrc,target=${localEnv:HOME}/.bashrc,type=bind,readonly,consistency=cached",
    "source=${localEnv:HOME}/code/util/profile,target=${localEnv:HOME}/code/util/profile,type=bind,readonly,consistency=cached"
  ],
  "remoteEnv": {
    "OPENAI_API_KEY": "fake-key",
    "TERM": "xterm-256color",
    "LANG": "en_US.UTF-8",
    "EDITOR": "nano",
    "CLAUDE_HOST_CONFIG_DIR": "/tmp/devcontainer-host/.claude",
    "CLAUDE_HOST_CONFIG_FILE": "/tmp/devcontainer-host/.claude.json",
    "HOST_BASHRC": "${localEnv:HOME}/.bashrc",
    "HOST_HOME": "${localEnv:HOME}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "bierner.markdown-mermaid"
      ]
    }
  },
  "updateRemoteUserUID": true,
  "remoteUser": "vscode"
}
